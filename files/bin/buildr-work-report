#!/usr/bin/env python3
"""Report active buildr repo work across git status + running coding agents."""

from __future__ import annotations

import argparse
import concurrent.futures
import datetime as dt
import fnmatch
import json
import os
import pathlib
import re
import subprocess
import sys
from typing import Any


DEFAULT_ROOT = str(pathlib.Path.home() / "code" / "buildr")
DEFAULT_PATTERN = "app*"
AGENT_TOOLS = ("pi", "codex", "claude")
AGENT_TOOL_RE = re.compile(rf"(?<![a-z0-9])({'|'.join(map(re.escape, AGENT_TOOLS))})(?![a-z0-9])", re.IGNORECASE)
DEFAULT_JOBS = max(1, min(16, (os.cpu_count() or 4)))
_GIT_ENV = {**os.environ, "GIT_OPTIONAL_LOCKS": "0"}


def run_command(args: list[str], check: bool = True) -> str:
    env = _GIT_ENV if args and args[0] == "git" else None
    result = subprocess.run(args, capture_output=True, text=True, env=env)
    if check and result.returncode != 0:
        raise RuntimeError(result.stderr.strip() or result.stdout.strip() or f"command failed: {' '.join(args)}")
    return result.stdout


def is_subpath(path: str, parent: str) -> bool:
    try:
        return os.path.commonpath((path, parent)) == parent
    except ValueError:
        return False


def discover_repos(root: pathlib.Path, pattern: str) -> list[dict[str, Any]]:
    repos: list[dict[str, Any]] = []
    if not root.exists():
        return repos

    for child in sorted(root.iterdir(), key=lambda p: p.name):
        if not child.is_dir():
            continue
        if not fnmatch.fnmatch(child.name, pattern):
            continue

        # Avoid spawning `git rev-parse` for every candidate: for normal repos,
        # worktrees, and submodules a .git dir/file is enough to identify the
        # checkout. The later status call will surface any broken repo errors.
        if not (child / ".git").exists():
            continue

        repos.append(
            {
                "name": child.name,
                "path": str(child.resolve()),
                "branch": None,
                "status": "unknown",
                "status_error": None,
                "agents": [],
                "agent_count": 0,
                "open": False,
            }
        )
    return repos


def parse_status_branch(header: str) -> str:
    branch_info = header[3:] if header.startswith("## ") else header
    if branch_info.startswith("No commits yet on "):
        return branch_info.removeprefix("No commits yet on ").split("...", 1)[0]
    if branch_info.startswith("HEAD"):
        return "(detached)"
    return branch_info.split("...", 1)[0] or "unknown"


def collect_repo_status(repo: dict[str, Any]) -> None:
    repo_path = repo["path"]
    try:
        # One git process gives us both the branch and dirty/clean state.
        porcelain = run_command(["git", "-C", repo_path, "status", "--porcelain=v1", "--branch"])
        lines = porcelain.splitlines()
        repo["branch"] = parse_status_branch(lines[0]) if lines else "unknown"
        repo["status"] = "clean" if len(lines) <= 1 else "dirty"
    except RuntimeError as exc:
        repo["status"] = "error"
        repo["status_error"] = str(exc)
        repo["branch"] = repo["branch"] or "unknown"


def detect_tool_from_command(command: str) -> str | None:
    match = AGENT_TOOL_RE.search(command)
    return match.group(1).lower() if match else None


def parse_ps_processes() -> list[dict[str, Any]]:
    try:
        output = run_command(["ps", "-axo", "pid=,command="])
    except RuntimeError:
        return []

    procs: list[dict[str, Any]] = []
    for raw_line in output.splitlines():
        line = raw_line.strip()
        if not line:
            continue
        parts = line.split(None, 1)
        if len(parts) != 2:
            continue
        pid_str, command = parts
        if not pid_str.isdigit():
            continue
        pid = int(pid_str)
        tool = detect_tool_from_command(command)
        if not tool:
            continue
        procs.append({"pid": pid, "tool": tool, "command": command})
    return procs


def collect_process_cwds(pids: list[int]) -> dict[int, str]:
    if not pids:
        return {}

    cwds: dict[int, str] = {}

    # Linux: /proc is dramatically faster than spawning lsof once per process.
    proc_root = pathlib.Path("/proc")
    if proc_root.exists():
        for pid in pids:
            try:
                cwds[pid] = os.path.realpath(os.readlink(proc_root / str(pid) / "cwd"))
            except OSError:
                pass
        return cwds

    # macOS/BSD fallback: one lsof for all PIDs, parsed as p<n>/n<cwd> fields.
    try:
        output = run_command(["lsof", "-a", "-d", "cwd", "-Fn", "-p", ",".join(map(str, pids))], check=False)
    except (OSError, RuntimeError):
        return cwds

    current_pid: int | None = None
    for line in output.splitlines():
        if line.startswith("p") and line[1:].isdigit():
            current_pid = int(line[1:])
        elif line.startswith("n") and current_pid is not None:
            cwds[current_pid] = line[1:]
    return cwds


def map_agents_to_repos(repos: list[dict[str, Any]], agents: list[dict[str, Any]]) -> list[dict[str, Any]]:
    repo_paths = sorted(((repo, repo["path"]) for repo in repos), key=lambda item: len(item[1]), reverse=True)
    cwd_by_pid = collect_process_cwds([agent["pid"] for agent in agents])
    unmapped: list[dict[str, Any]] = []

    for agent in agents:
        cwd = cwd_by_pid.get(agent["pid"])
        agent["cwd"] = cwd
        matched_repo: dict[str, Any] | None = None

        if cwd:
            cwd_real = os.path.realpath(cwd)
            for repo, repo_path in repo_paths:
                if is_subpath(cwd_real, repo_path):
                    matched_repo = repo
                    break

        if matched_repo is None:
            agent["repo"] = None
            unmapped.append(agent)
        else:
            agent["repo"] = matched_repo["name"]
            matched_repo["agents"].append({"tool": agent["tool"], "pid": agent["pid"], "cwd": cwd})

    for repo in repos:
        repo["agent_count"] = len(repo["agents"])

    return unmapped


def compute_open_repos(repos: list[dict[str, Any]]) -> list[str]:
    open_repos = [repo["name"] for repo in repos if repo["status"] == "clean" and repo["agent_count"] == 0]
    return sorted(open_repos)


def choose_open_repo(open_repos: list[str]) -> str | None:
    return open_repos[0] if open_repos else None


def render_table(repos: list[dict[str, Any]], open_repos: list[str], suggested_open_repo: str | None, verbose: bool = False) -> str:
    headers = ["REPO", "BRANCH", "STATUS", "AGENTS", "OPEN"]
    rows: list[list[str]] = []

    for repo in repos:
        agents = ", ".join(f"{a['tool']}({a['pid']})" for a in repo["agents"]) if repo["agents"] else "-"
        rows.append(
            [
                repo["name"],
                repo.get("branch") or "unknown",
                repo["status"],
                agents,
                "yes" if repo["open"] else "no",
            ]
        )

    widths = [len(h) for h in headers]
    for row in rows:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], len(cell))

    def fmt_row(cells: list[str]) -> str:
        return "  ".join(cell.ljust(widths[i]) for i, cell in enumerate(cells))

    lines = [fmt_row(headers), fmt_row(["-" * w for w in widths])]
    lines.extend(fmt_row(row) for row in rows)

    lines.append("")
    lines.append(f"Open repos ({len(open_repos)}): {', '.join(open_repos) if open_repos else '-'}")
    lines.append(f"Suggested open repo: {suggested_open_repo or '-'}")

    if verbose:
        error_repos = [r for r in repos if r.get("status") == "error" and r.get("status_error")]
        if error_repos:
            lines.append("")
            lines.append("Repo status errors:")
            for repo in error_repos:
                lines.append(f"- {repo['name']}: {repo['status_error']}")

    return "\n".join(lines)


def build_report(root: pathlib.Path, repos_pattern: str, only_open: bool = False, jobs: int = DEFAULT_JOBS) -> dict[str, Any]:
    repos = discover_repos(root, repos_pattern)

    if repos:
        with concurrent.futures.ThreadPoolExecutor(max_workers=max(1, min(jobs, len(repos)))) as executor:
            list(executor.map(collect_repo_status, repos))

    agents = parse_ps_processes()
    unmapped_agents = map_agents_to_repos(repos, agents)

    open_repos = compute_open_repos(repos)
    suggested_open_repo = choose_open_repo(open_repos)

    for repo in repos:
        repo["open"] = repo["name"] in open_repos

    if only_open:
        repos = [repo for repo in repos if repo["open"]]

    return {
        "root": str(root),
        "generated_at": dt.datetime.now().astimezone().isoformat(),
        "repos_pattern": repos_pattern,
        "repos": repos,
        "agents": agents,
        "open_repos": open_repos,
        "suggested_open_repo": suggested_open_repo,
        "unmapped_agents": unmapped_agents,
    }


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Report buildr repo status + active coding agents")
    parser.add_argument("--root", default=DEFAULT_ROOT, help="Root directory containing app repos")
    parser.add_argument("--repos-pattern", default=DEFAULT_PATTERN, help="Directory glob for repos (default: app*)")
    parser.add_argument("--format", choices=("table", "json"), default="table", help="Output format (default: table)")
    parser.add_argument("--only-open", action="store_true", help="Only include open repos in repo listing")
    parser.add_argument("--verbose", action="store_true", help="Include extra diagnostics in table mode")
    parser.add_argument("--jobs", type=int, default=DEFAULT_JOBS, help=f"Concurrent git status jobs (default: {DEFAULT_JOBS})")
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    report = build_report(pathlib.Path(args.root), args.repos_pattern, only_open=args.only_open, jobs=args.jobs)

    if args.format == "json":
        print(json.dumps(report, indent=2))
        return 0

    print(render_table(report["repos"], report["open_repos"], report["suggested_open_repo"], verbose=args.verbose))
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
