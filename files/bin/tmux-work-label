#!/usr/bin/env bash
set -euo pipefail

path="${1:-$PWD}"

if [[ -d "$path" ]]; then
  dir="$path"
else
  dir="${path%/*}"
  [[ "$dir" == "$path" ]] && dir="."
fi

fallback_label="${dir##*/}"
[[ -z "$fallback_label" ]] && fallback_label="/"
if ! dir="$(cd -- "$dir" 2>/dev/null && pwd -P)"; then
  printf '%s\n' "$fallback_label"
  exit 0
fi

label="${dir##*/}"
[[ -z "$label" ]] && label="/"
search="$dir"

while [[ -n "$search" && "$search" != "/" ]]; do
  git_meta="$search/.git"
  if [[ -e "$git_meta" ]]; then
    label="${search##*/}"

    # .git can be a directory or a gitfile (worktrees/submodules).
    if [[ -f "$git_meta" ]]; then
      IFS= read -r gitdir_line < "$git_meta" || gitdir_line=""
      if [[ "$gitdir_line" == gitdir:* ]]; then
        gitdir="${gitdir_line#gitdir: }"
        [[ "$gitdir" != /* ]] && gitdir="$search/$gitdir"
        git_meta="$gitdir"
      fi
    fi

    if [[ -r "$git_meta/HEAD" ]]; then
      IFS= read -r head < "$git_meta/HEAD" || head=""
      if [[ "$head" == ref:\ refs/heads/* ]]; then
        printf '%s (%s)\n' "$label" "${head#ref: refs/heads/}"
        exit 0
      elif [[ -n "$head" ]]; then
        printf '%s (%s)\n' "$label" "${head:0:7}"
        exit 0
      fi
    fi

    printf '%s\n' "$label"
    exit 0
  fi

  parent="${search%/*}"
  [[ "$parent" == "$search" ]] && break
  [[ -z "$parent" ]] && parent="/"
  search="$parent"
done

printf '%s\n' "$label"
